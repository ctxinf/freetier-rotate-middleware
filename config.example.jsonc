{
  // Service port (can still be overridden by env PORT)
  "port": 3000,

  // Upstream OpenAI-compatible base URL (can still be overridden by env UPSTREAM_BASE_URL)
  "upstreamBaseUrl": "http://localhost:8080",

  // Authorization header will be transparently forwarded to upstream.

  // SQLite path (can still be overridden by env DATABASE_PATH)
  "databasePath": "./data/gateway.sqlite",

  // How to sync routeItems into sqlite on startup:
  // - authoritative: insert/update items from config, and set enabled=0 for DB rows not present here
  // - merge: insert/update items from config, do not touch other DB rows
  "routeItemsMode": "authoritative",

  "routeItems": [
    // req/min + req/day 双重限制 (示例 1)
    {
      "publicModel": "gpt-4o-mini",
      "upstreamModel": "gpt-4o-mini",
      "strategyType": "req_min_day",
      "priority": 100,
      "enabled": 1,
      "config": { "reqPerMin": 5, "reqPerDay": 100 }
    },

    // token/day (示例 2) - dailyTokenLimit 单位是 M(百万 token)；resetHourUtc=8 表示每天 08:00 UTC 刷新
    {
      "publicModel": "doubao-seed-xxx",
      "upstreamModel": "doubao-seed-xxx",
      "strategyType": "token_day",
      "priority": 100,
      "enabled": 1,
      "config": {
        // "dailyTokenLimit": 2000000, //🉑
        // "dailyTokenLimitM": 2,//🉑
        "dailyTokenLimit": "2M",
        "resetHourUtc": 8,
        "reserveMultiplier": 1.2,
        "reserveFloor": 64
      }
    },

    // 同一个 publicModel 多个候选 (示例 3) - 用 priority 控制优先级
    {
      "publicModel": "gpt-4o-mini",
      "upstreamModel": "gpt-4o-mini-2024-07-18",
      "strategyType": "req_min_day",
      "priority": 90,
      "enabled": 1,
      "config": { "reqPerMin": 2, "reqPerDay": 50 }
    },

    // configJson 也可以直接给字符串 (示例 4)
    {
      "publicModel": "gemini-2.0-flash",
      "upstreamModel": "gemini-2.0-flash",
      "strategyType": "req_min_day",
      "priority": 100,
      "enabled": 1,
      "configJson": "{\"reqPerMin\":5,\"reqPerDay\":100}"
    },

    // disabled 示例 (示例 5)
    {
      "publicModel": "gpt-4.1",
      "upstreamModel": "gpt-4.1",
      "strategyType": "token_day",
      "priority": 100,
      "enabled": 0,
      "config": { "dailyTokenLimit": 0.5, "resetHourUtc": 0 }
    }
  ]
}
