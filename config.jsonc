{
  // Service port (can still be overridden by env PORT)
  "port": 3000,

  // Upstream OpenAI-compatible base URL (can still be overridden by env UPSTREAM_BASE_URL)
  "upstreamBaseUrl": "http://localhost:8080",

  // Authorization header will be transparently forwarded to upstream.

  // SQLite path (can still be overridden by env DATABASE_PATH)
  "databasePath": "./data/gateway.sqlite",

  // How to sync routeItems into sqlite on startup:
  // - authoritative: insert/update items from config, and set enabled=0 for DB rows not present here
  // - merge: insert/update items from config, do not touch other DB rows
  "routeItemsMode": "authoritative",

  "routeItems": [
    {
      "publicModel": "my-api:free",
      "upstreamModel": "doubao-seed-2-0-pro-260215",
      "strategyType": "token_day",
      "priority": 100,
      "enabled": 1,
      "config": {
        "dailyTokenLimit": "2M",
        "resetHourUtc": 8,
        "reserveMultiplier": 1.2,
        "reserveFloor": 64
      }
    },
